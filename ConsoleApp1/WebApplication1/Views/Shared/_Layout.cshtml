<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>My Portfolio</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <style>

            body{
                overflow-x:hidden;
            }

            .sidebar{
                height:100vh;
                position:fixed;
                width:230px;
                background:#212529;
            }

            .sidebar a{
                color:white;
                text-decoration:none;
                display:block;
                padding:15px;
            }

            .sidebar a:hover{
                background:#343a40;
            }

            .content{
                margin-left:230px;
                padding:30px;
            }

            @@media(max-width:768px){

                .sidebar{
                    position:relative;
                    width:100%;
                    height:auto;
                }

                .content{
                    margin-left:0;
                }

            }

    </style>

</head>

<body>

    <div class="sidebar">

        <h3 class="text-center text-white mt-3">Portfolio</h3>

        <a href="#home">Home</a>
        <a href="#about">About Me</a>
        <a href="#skills">Skills</a>
        <a href="#projects">Projects</a>
        <a href="#contact">Contact</a>

    </div>

    <div class="content">

        @RenderBody()

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>